{
  "functions": {
    "app/api/download/[filename]/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/download/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/BitshredW.exe",
      "destination": "/api/download/BitshredW.exe",
      "permanent": false
    },
    {
      "source": "/Bitshred.exe", 
      "destination": "/api/download/Bitshred.exe",
      "permanent": false
    }
  ]
}